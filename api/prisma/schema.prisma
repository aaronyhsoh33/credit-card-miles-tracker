generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  label     String
  icon      String
  createdAt DateTime @default(now())

  rateRules    CardRateRule[]
  transactions Transaction[]
}

model Card {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  bank        String
  network     String
  annualFee   Int      // SGD cents
  baseRateMpd Decimal  @db.Decimal(5, 2)
  imagePath   String   @default("")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rateRules    CardRateRule[]
  userCards    UserCard[]
  transactions Transaction[]
}

model CardRateRule {
  id         Int      @id @default(autoincrement())
  cardId     Int
  categoryId Int
  mpd        Decimal  @db.Decimal(5, 2)
  minSpend   Decimal? @db.Decimal(10, 2)
  monthlyCap Decimal? @db.Decimal(10, 2)
  notes      String?
  createdAt  DateTime @default(now())

  card     Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([cardId, categoryId, mpd])
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userCards     UserCard[]
  transactions  Transaction[]
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserCard {
  id       Int      @id @default(autoincrement())
  userId   Int
  cardId   Int
  nickname String?
  addedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
}

model Transaction {
  id           Int      @id @default(autoincrement())
  userId       Int
  cardId       Int
  categoryId   Int
  amount       Decimal  @db.Decimal(10, 2)
  merchant     String?
  notes        String?
  transactedAt DateTime
  milesEarned  Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card     Card     @relation(fields: [cardId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])
}
